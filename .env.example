APP_NAME=Orders Connector
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/orders_connector
DB_ECHO=false
DB_AUTO_CREATE=false

SCHEDULER_ENABLED=true
POLLING_INTERVAL_SECONDS=30
POLLING_RETRY_ATTEMPTS=3
POLLING_RETRY_BASE_DELAY_SECONDS=1
ORDERS_ACTIVE_MODE=false
ENABLED_AUTOMATIC_ACTIONS=confirm

HTTP_TIMEOUT_SECONDS=15
LOG_LEVEL=INFO

IFOOD_EVENTS_BASE_URL=https://merchant-api.ifood.com.br/events/v1.0
IFOOD_ORDERS_BASE_URL=https://merchant-api.ifood.com.br/order/v1.0
IFOOD_POLLING_MERCHANTS=

# Preferred for early local tests:
IFOOD_BEARER_TOKEN=

# Use these when implementing the full refresh flow:
IFOOD_TOKEN_URL=
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=
IFOOD_REFRESH_TOKEN=
